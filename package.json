{
  "name": "ghostpath-cli",
  "version": "1.1.0",
  "description": "Auto-fill current VS Code active file path in terminal via tab/ghost suggestion",
  "main": "index.js",
  "bin": {
    "ghostpath": "./bin/ghostpath.js"
  },
  "scripts": {
    "postinstall": "node bin/ghostpath.js setup --silent",
    "prepublishOnly": "cd vscode-extension && node build-extension.js && npx --yes @vscode/vsce package --out ghostpath-vscode.vsix"
  },
  "keywords": [
    "vscode",
    "terminal",
    "autocomplete",
    "file-path",
    "zsh",
    "powershell"
  ],
  "author": "Vyas Akondi <vyas.akondi@zohomail.in>",
  "license": "MIT",
  "files": [
    "bin/",
    "shell/",
    "vscode-extension/",
    "index.js"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vyas-Akondi/ghostpath-cli.git"
  },
  "bugs": {
    "url": "https://github.com/Vyas-Akondi/ghostpath-cli/issues"
  },
  "homepage": "https://github.com/Vyas-Akondi/ghostpath-cli#readme"
}
