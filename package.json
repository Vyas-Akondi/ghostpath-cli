    "node": ">=14.0.0"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vyas-Akondi/ghostpath-cli.git"
  },
  "bugs": {
